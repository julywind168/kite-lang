// 1. Extern 声明：对接 C 库
extern struct Vector3 {
    x: f32,
    y: f32,
    z: f32
}

extern fn InitWindow(width: i32, height: i32, title: string)

// 2. 导出结构体
pub struct Entity {
    position: Vector3,
    velocity: Vector3,
    state: EntityState
}

// 3. 顶层函数定义
fn get_default_speed() f32 {
    10.5
}

fn calculate_physics(pos: Vector3, dt: f32) Vector3 {
    let speed = get_default_speed()
    { x: pos.x + speed * dt, y: pos.y, z: pos.z }
}

type EntityState = Idle | Moving(Vector3) | Destroyed

// 4. 模式匹配与匿名函数 (使用 =>)
fn update_state(state: EntityState) EntityState {
    match state {
        | Idle => Moving({ x: 0.0, y: 0.0, z: 0.0 })
        | Moving(p) => Moving(calculate_physics(p, 0.016))
        | _ => state
    }
}

// 5. 不可变绑定（let 默认不可变）
let max_entities = 100
let default_title: string = "Kite Window"
let gravity: Vector3 = { x: 0.0, y: -9.8, z: 0.0 }

// 6. 管道符、高阶函数、索引访问
pub fn main() {
    let entities = [Idle, Moving({ x: 1.0, y: 0.0, z: 0.0 })]

    // 匿名函数使用 =>
    let active_entities = entities
        |> List.map(s => update_state(s))
        |> List.filter(s => {
            match s {
                | Moving(p) => p.x < 100.0
                | _ => true
            }
        })

    // 索引访问与字段访问
    let first = active_entities[0]
    let can_spawn = active_entities.length < max_entities

    let summary = if first == Idle {
        "No active movement"
    } else {
        "Active entities present"
    }

    echo "Kite engine initialized, " <> summary
}

test "default speed is positive" {
    get_default_speed() > 0.0
}

// 7. with 表达式：回调语法糖（等价 Gleam 的 use）
// 将后续代码块作为回调传入，消除嵌套
fn process_profiles(user_ids: [string]) [Profile] {
    with db <- connect_database("game.db")
    with user <- db.find_user("player_1")
    let profile = user.load_profile()
    db.save_profile(profile)
    profile
}

