// 9. 和类型带判别值：可映射到 int（兼容 C ABI）
type FileError = NotFound = 1 | PermissionDenied = 5 | IoError(string) = -1

// 使用 Result 类型处理错误，? 传播
fn read_config(path: string) Result(string, FileError) {
    let file = open_file(path)?        // ? 遇到 Err 则提前返回
    let content = file.read_all()?
    content
}

fn load_default_config() string {
    open_file("default.conf")!.read_all()!
}

// 10. echo 调试表达式：求值并打印，返回原值
fn debug_physics(pos: Vector3, dt: f32) Vector3 {
    let result = echo calculate_physics(pos, dt)
    result
}

// 11. 逻辑运算符：and / or / not
fn should_cull(entity: Entity, bounds: Bounds) bool {
    let in_view = entity.position.x > bounds.min.x
        and entity.position.x < bounds.max.x
        and entity.position.z > bounds.min.z
        and entity.position.z < bounds.max.z

    let is_active = match entity.state {
        | Idle => true
        | Destroyed => false
        | Moving(p) => p.y > -50.0
    }

    // not 替代 !，or 替代 ||
    not in_view or not is_active
}

