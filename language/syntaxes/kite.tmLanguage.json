{
  "scopeName": "source.kite",
  "name": "Kite",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {
      "comment": "函数定义：匹配 fn 后面的名称",
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.kite" },
        "2": { "name": "entity.name.function.kite" }
      }
    },
    {
      "comment": "类型定义：匹配 (pub|extern) struct/type 名称",
      "match": "\\b(?:(pub|extern)\\s+)?(struct|type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.kite" },
        "2": { "name": "storage.type.kite" },
        "3": { "name": "entity.name.type.kite" }
      }
    },
    {
      "comment": "枚举变体：同时捕获符号和标识符",
      "match": "(\\||=)\\s*([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.operator.kite" },
        "2": { "name": "variable.other.enummember.kite" }
      }
    },
    {
      "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|string|char|void|usize)\\b",
      "name": "storage.type.primitive.kite"
    },
    {
      "match": "\\b(let|pub|fn|extern|var|struct|type|if|else|match|with|todo|echo|import|test|true|false|and|or|not)\\b",
      "name": "keyword.control.kite"
    },
    {
      "comment": "函数调用：匹配后面跟着左括号的标识符",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.kite"
    },
    {"include": "#operators"},
    {"include": "#discards"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"name": "comment.line.double-slash.kite", "match": "//.*$"},
        {"name": "comment.block.kite", "begin": "/\\*", "end": "\\*/"}
      ]
    },
    "strings": {
      "patterns": [
        {"name": "string.quoted.double.kite", "begin": "\"", "end": "\"", "patterns": [{"match": "\\\\.", "name": "constant.character.escape.kite"}]},
        {"name": "string.quoted.single.kite", "begin": "'", "end": "'", "patterns": [{"match": "\\\\.", "name": "constant.character.escape.kite"}]}
      ]
    },
    "numbers": {
      "patterns": [
        {"name": "constant.numeric.kite", "match": "\\b\\d+(\\\\.\\d+)?\\b"}
      ]
    }
    ,
    "operators": {
      "patterns": [
        {"name": "keyword.operator.kite", "match": "<>"},
        {"name": "keyword.operator.kite", "match": "<-"},
        {"name": "keyword.operator.kite", "match": "\\|>"},
        {"name": "keyword.operator.kite", "match": "=="},
        {"name": "keyword.operator.kite", "match": "!="},
        {"name": "keyword.operator.kite", "match": "<="},
        {"name": "keyword.operator.kite", "match": ">="},
        {"name": "keyword.operator.kite", "match": "->"},
        {"name": "keyword.operator.kite", "match": "=>"},
        {"name": "keyword.operator.kite", "match": "="},
        {"name": "keyword.operator.kite", "match": "<"},
        {"name": "keyword.operator.kite", "match": ">"},
        {"name": "keyword.operator.kite", "match": ":"},
        {"name": "keyword.operator.kite", "match": "!"},
        {"name": "keyword.operator.kite", "match": "\\?"},
        {"name": "keyword.operator.kite", "match": "\\."},
        {"name": "keyword.operator.kite", "match": "\\+"},
        {"name": "keyword.operator.kite", "match": "\\-"},
        {"name": "keyword.operator.kite", "match": "\\*"},
        {"name": "keyword.operator.kite", "match": "/"},
        {"name": "keyword.operator.kite", "match": "%"},
        {"name": "keyword.operator.kite", "match": "\\|"}
      ]
    },
    "discards": {
      "name": "comment.unused.kite",
      "match": "\\b_[A-Za-z0-9_]*\\b"
    }
  },
  "fileTypes": ["kite"]
}
