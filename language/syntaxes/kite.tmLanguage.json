{
  "scopeName": "source.kite",
  "name": "Kite",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {"include": "#operators"},
    {
      "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|string|char|void|usize)\\b",
      "name": "storage.type.primitive.kite"
    },
    {
      "match": "\\b(let|pub|fn|extern|var|struct|type|if|else|match|with|todo|echo|import|export|test|true|false|and|or|not)\\b",
      "name": "keyword.control.kite"
    },
    {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b",
      "name": "identifier.kite"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"name": "comment.line.double-slash.kite", "match": "//.*$"},
        {"name": "comment.block.kite", "begin": "/\\*", "end": "\\*/"}
      ]
    },
    "strings": {
      "patterns": [
        {"name": "string.quoted.double.kite", "begin": "\"", "end": "\"", "patterns": [{"match": "\\\\.", "name": "constant.character.escape.kite"}]},
        {"name": "string.quoted.single.kite", "begin": "'", "end": "'", "patterns": [{"match": "\\\\.", "name": "constant.character.escape.kite"}]}
      ]
    },
    "numbers": {
      "patterns": [
        {"name": "constant.numeric.kite", "match": "\\b\\d+(\\\\.\\d+)?\\b"}
      ]
    }
    ,
    "operators": {
      "patterns": [
        {"name": "keyword.operator.kite", "match": "<>"},
        {"name": "keyword.operator.kite", "match": "<-"},
        {"name": "keyword.operator.kite", "match": "\\|>"},
        {"name": "keyword.operator.kite", "match": "=="},
        {"name": "keyword.operator.kite", "match": "!="},
        {"name": "keyword.operator.kite", "match": "<="},
        {"name": "keyword.operator.kite", "match": ">="},
        {"name": "keyword.operator.kite", "match": "->"},
        {"name": "keyword.operator.kite", "match": "=>"},
        {"name": "keyword.operator.kite", "match": "!"},
        {"name": "keyword.operator.kite", "match": "\\?"},
        {"name": "keyword.operator.kite", "match": "\\."},
        {"name": "keyword.operator.kite", "match": "\\+"},
        {"name": "keyword.operator.kite", "match": "\\-"},
        {"name": "keyword.operator.kite", "match": "\\*"},
        {"name": "keyword.operator.kite", "match": "/"},
        {"name": "keyword.operator.kite", "match": "%"},
        {"name": "keyword.operator.kite", "match": "\\|"}
      ]
    }
  },
  "fileTypes": ["kite"]
}
